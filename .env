NODE_ENV=development
PORT=3000

# Optional (Redis for caching)
REDIS_HOST=localhost
REDIS_PORT=6379


# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hrm_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=HRM System
SMTP_FROM_EMAIL=noreply@hrmsystem.com

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Security Settings
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
BLOCK_DURATION_MINUTES=30
OTP_EXPIRY_MINUTES=5
OTP_EXPIRY_PASSWORD_MINUTES=15
PASSWORD_HISTORY_COUNT=3
API_KEY=your-service-api-key-here-change-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000
