# Environment
NODE_ENV=development
APP_VERSION=1.0.0
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hrm_db

# Redis (optional but recommended for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Or use Redis URL
# REDIS_URL=redis://localhost:6379

# JWT Configuration (IMPORTANT: Change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=HRM System
SMTP_FROM_EMAIL=noreply@hrmsystem.com

# Frontend URL
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:3000

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3000,http://localhost:3001

# Security Settings
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
BLOCK_DURATION_MINUTES=30
OTP_EXPIRY_MINUTES=5
OTP_EXPIRY_PASSWORD_MINUTES=15
PASSWORD_HISTORY_COUNT=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_DEFAULT_TTL=300
CACHE_USER_TTL=300
CACHE_LIST_TTL=60

# Logging
LOG_LEVEL=info
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m
