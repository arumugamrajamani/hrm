# ===================
# Application Settings
# ===================
NODE_ENV=development
APP_VERSION=2.0.0
PORT=3000

# ===================
# Database Configuration
# ===================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hrm
DB_PORT=3306
DB_POOL_SIZE=20
DB_QUEUE_LIMIT=100
DB_REPLICA_HOST=
DB_REPLICA_PORT=3306

# ===================
# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=

# Bull Queue Redis DB (separate from cache)
BULL_REDIS_DB=1

# ===================
# JWT Configuration
# ===================
JWT_SECRET=your-super-secret-jwt-access-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-minimum-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ALGORITHM=HS256
JWT_KEY_ROTATION=false
JWT_KEY_ID=default

# ===================
# Security Settings
# ===================
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
BLOCK_DURATION_MINUTES=30
OTP_EXPIRY_MINUTES=5
OTP_EXPIRY_PASSWORD_MINUTES=15
PASSWORD_HISTORY_COUNT=3
BCRYPT_ROUNDS=12
TOTP_ISSUER=HRM System
TOTP_WINDOW=1
API_KEY=your-service-api-key-here-change-in-production

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=5
RATE_LIMIT_OTP_WINDOW_MS=60000
RATE_LIMIT_OTP_MAX_REQUESTS=3
RATE_LIMIT_USER_WINDOW_MS=60000
RATE_LIMIT_USER_MAX_REQUESTS=100

# ===================
# Caching
# ===================
CACHE_DEFAULT_TTL=300
CACHE_USER_TTL=300
CACHE_LIST_TTL=60

# ===================
# Logging
# ===================
LOG_LEVEL=info
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m
LOG_SANITIZE_FIELDS=password,token,secret,authorization,cookie,accessToken,refreshToken,newPassword,currentPassword,otp,apiKey,apiSecret
LOG_MASK_CHAR=*

# ===================
# SMTP Configuration
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=HRM System
SMTP_FROM_EMAIL=noreply@hrmsystem.com

# ===================
# CORS & Origins
# ===================
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3000
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:3000
API_VERSION=v1

# ===================
# Circuit Breaker
# ===================
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_TIMEOUT=5000
CIRCUIT_BREAKER_RESET_TIMEOUT=30000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50

# ===================
# Multi-Tenancy
# ===================
MULTI_TENANCY_ENABLED=false
TENANT_SCHEMA_STRATEGY=database

# ===================
# Webhooks
# ===================
WEBHOOK_ENABLED=false
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# ===================
# File Upload
# ===================
FILE_STORAGE_TYPE=local
MAX_FILE_SIZE=5242880
ALLOWED_FILE_EXTENSIONS=jpeg,jpg,png,gif,webp,pdf,doc,docx,xls,xlsx

# ===================
# Metrics
# ===================
METRICS_ENABLED=false
METRICS_PORT=9090
